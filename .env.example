# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/inci_db

# PubMed API identification
NCBI_EMAIL=your_email@example.com
NCBI_TOOL=graph_rag_pipeline
NCBI_API_KEY=

# API request configuration
REQUEST_TIMEOUT=30
REQUEST_SLEEP=0.34

# PubMed search
SEARCH_LIMIT=20

# Data path
TARGET_CSV_PATH=data/target_ingredients.csv

#Bronze
BRONZE_ROOT_DIR=bronze
BRONZE_DOMAIN_DIR=pubmed
ENABLE_DB_UPSERT=true

#Silver
SILVER_ROOT_DIR=silver
SILVER_DOMAIN_DIR=paper
ENABLE_CHUNK_DB_UPSERT=false

#gold
GOLD_ROOT_DIR=gold
GOLD_DOMAIN_DIR=claim
ENABLE_CLAIM_DB_UPSERT=false

GOLD_TEST_CHUNK_LIMIT=100000
GOLD_DEBUG_PRINT_LIMIT=10

EXTRACTOR_VERSION=llm_claim_extractor_v1
VALIDATOR_VERSION=claim_validator_v1
MAPPING_VERSION=taxonomy_mapping_v1

CHUNK_MAX_CHARS=1000
CHUNK_OVERLAP_CHARS=150
CHUNK_VERSION=abstract_char_window_v1